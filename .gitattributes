# Normalize line endings to LF in the repo. Editors on Windows handle LF cleanly;
# this prevents noisy diffs when files are touched from different machines.
* text=auto eol=lf

# Source files — explicit LF
*.js   text eol=lf
*.html text eol=lf
*.css  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.sh   text eol=lf
*.gpl  text eol=lf

# Binary assets — never normalize, never diff as text
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.webp     binary
*.ico      binary
*.aseprite binary
*.ase      binary
*.zip      binary
*.gz       binary
*.mp3      binary
*.wav      binary
*.ogg      binary
*.ttf      binary
*.otf      binary
*.woff     binary
*.woff2    binary
*.pdf      binary
